<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/space_cadet">

    <org.hzontal.shared_ui.appbar.ToolbarComponent
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:arrowBackIcon="@drawable/ic_close_white_24dp"
        app:arrowBackIconContentDescription="@string/action_go_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/AppTheme.PopupOverlay"
        app:rightIconContentDescription="@string/action_save"
        app:startTitle="@string/nearby_sharing_results_title" />

    <ImageView
        android:id="@+id/setupImgV"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:contentDescription="@string/Server_Connect_Icon"
        android:src="@drawable/checked_circle"
        app:layout_constraintBottom_toTopOf="@+id/tileTv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:layout_editor_absoluteX="175dp" />

    <TextView
        android:id="@+id/tileTv"
        style="@style/Unlock_White_Text_Bold"
        tools:text="Success"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/descriptionTv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/setupImgV" />

    <TextView
        android:id="@+id/descriptionTv"
        style="@style/Unlock_White_Text_Medium"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="@dimen/activity_horizontal_margin"
        tools:text="You have successfully sent 6 files to the recipient."
        app:layout_constraintBottom_toTopOf="@+id/action_buttons_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tileTv" />

    <FrameLayout
        android:id="@+id/action_buttons_container"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginHorizontal="@dimen/activity_horizontal_margin"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="@dimen/activity_horizontal_margin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/descriptionTv">

        <org.hzontal.shared_ui.buttons.RoundButton
            android:id="@+id/view_files_btn"
            style="@style/Tella_Main_White_TextLargeBold"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_round_orange_btn"
            android:text="@string/view_files"
            app:check_state="true"
            app:default_background="@drawable/bg_round_orange_btn"
            app:text_color="@color/btn_dark_letter" />

        <org.hzontal.shared_ui.buttons.RoundButton
            android:id="@+id/back_to_home_btn"
            style="@style/Tella_Main_White_TextLargeBold"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_information_button"
            android:visibility="gone"
            app:check_state="false"
            app:default_background="@drawable/bg_information_button"
            app:text="@string/back_to_home_action"
            app:text_color="@color/wa_white" />

    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>