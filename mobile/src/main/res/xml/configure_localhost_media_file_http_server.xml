<?xml version="1.0" encoding="utf-8"?>
<!--
  SECURITY: Cleartext must NOT be permitted globally.
  Audit finding: cleartext was previously re-introduced via base-config.
  Only localhost is allowed for local media/HTTP server; all other traffic must use HTTPS.
-->
<network-security-config>
    <!-- Default: no cleartext. Do not set cleartextTrafficPermitted="true" here. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust preinstalled CAs -->
            <certificates src="system"/>
            <!-- Additionally trust user added CAs -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

    <!-- Exception: cleartext only for localhost (local media/HTTP server). -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
